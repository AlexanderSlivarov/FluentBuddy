<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.GrammarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Grammar">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Grammar Correction"
               FontSize="24"
               FontAttributes="Bold" />

            <Editor x:Name="SentenceEditor"
                Placeholder="Write a sentence..."
                AutoSize="TextChanges"
                HeightRequest="120" />

            <Button Text="Correct Sentence"
                Clicked="OnCorrectClicked" />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Corrected Sentence:" FontAttributes="Bold" />
                    <Label x:Name="CorrectedLabel" />

                    <Label Text="Explanation:" FontAttributes="Bold" />
                    <Label x:Name="ExplanationLabel" />

                    <Label Text="Example:" FontAttributes="Bold" />
                    <Label x:Name="ExampleLabel" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>