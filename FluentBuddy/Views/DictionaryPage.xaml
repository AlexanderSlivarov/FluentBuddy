<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.DictionaryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dictionary"
    BackgroundColor="#111827">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="settings.png"
            Order="Primary"
            Priority="0"
            Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">
           
            <VerticalStackLayout Spacing="6">
                <Label
                    Text="AI Dictionary"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Label
                    Text="Explore meaning, forms, synonyms, antonyms, and real usage examples."
                    FontSize="14"
                    TextColor="#9CA3AF" />
            </VerticalStackLayout>
            
            <Border
                Stroke="#2A3342"
                StrokeThickness="1"
                BackgroundColor="#1F2937"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <VerticalStackLayout Spacing="14">
                    <Label
                        Text="Search a word"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#E5E7EB" />

                    <Border
                        BackgroundColor="#111827"
                        Stroke="#374151"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="12,4">

                        <Entry
                            x:Name="WordEntry"
                            Placeholder="Enter a word"
                            PlaceholderColor="#6B7280"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            FontSize="16"
                            ClearButtonVisibility="WhileEditing" />
                    </Border>

                    <Button
                        x:Name="AnalyzeButton"
                        Text="Analyze Word"
                        Clicked="OnAnalyzeClicked"
                        HeightRequest="52"
                        CornerRadius="16"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="#A78BFA"
                        TextColor="#111827" />
                </VerticalStackLayout>
            </Border>
            
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="2">
                    <Label
                        Text="Analysis Result"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White" />
                    <Label
                        Text="Detailed AI breakdown of the selected word"
                        FontSize="13"
                        TextColor="#9CA3AF" />
                </VerticalStackLayout>
                
            </Grid>
         
            <Border
                Padding="18"
                BackgroundColor="#1F2937"
                Stroke="#2A3342"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24">

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Word"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#A78BFA" />
                        <Label
                            x:Name="WordLabel"
                            Text="No word analyzed yet."
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="White" />
                    </VerticalStackLayout>
                 
                    <Border
                        BackgroundColor="#111827"
                        Stroke="#2F3A4C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Meaning" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                            <Label x:Name="MeaningLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.35" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#111827"
                            Stroke="#2F3A4C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Part of Speech" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                                <Label x:Name="PartOfSpeechLabel" Text="—" TextColor="#D1D5DB" FontSize="14" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Column="1"
                            BackgroundColor="#111827"
                            Stroke="#2F3A4C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Forms" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                                <Label x:Name="FormsLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.3" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <Border
                        BackgroundColor="#111827"
                        Stroke="#2F3A4C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Word Family" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                            <Label x:Name="WordFamilyLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.35" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="#111827"
                            Stroke="#2F3A4C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Synonyms" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                                <Label x:Name="SynonymsLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.35" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Column="1"
                            BackgroundColor="#111827"
                            Stroke="#2F3A4C"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Antonyms" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                                <Label x:Name="AntonymsLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.35" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border
                        BackgroundColor="#111827"
                        Stroke="#2F3A4C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Examples" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                            <Label x:Name="ExamplesLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Border>
  
                    <Border
                        BackgroundColor="#111827"
                        Stroke="#2F3A4C"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Usage" FontAttributes="Bold" FontSize="15" TextColor="#E5E7EB" />
                            <Label x:Name="UsageLabel" Text="—" TextColor="#D1D5DB" FontSize="14" LineHeight="1.4" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>