<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Chat"
    BackgroundColor="#1E1E1E">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                Text="AI Chat Practice"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="#B794F4" />

            <Editor
                x:Name="UserMessageEditor"
                Placeholder="Type your message in English..."
                PlaceholderColor="#BBBBBB"
                TextColor="White"
                BackgroundColor="#2A2A2A"
                AutoSize="TextChanges"
                HeightRequest="120" />

            <Button
                Text="Send"
                Clicked="OnSendClicked"
                BackgroundColor="#B794F4"
                TextColor="Black" />

            <Label
                Text="AI Response"
                FontAttributes="Bold"
                FontSize="18"
                TextColor="White" />

            <Border
                Padding="16"
                BackgroundColor="#2A2A2A">
                
                <Label
                    x:Name="ResponseLabel"
                    Text="Your AI response will appear here."
                    TextColor="White" />
                
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>