<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.QuizPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Quiz"
    BackgroundColor="#111827">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="settings.png"
            Order="Primary"
            Priority="0"
            Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label
                    Text="AI Quiz"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="White" />

                <Label
                    Text="Generate a quiz, answer questions, and evaluate your performance."
                    FontSize="14"
                    TextColor="#9CA3AF" />
            </VerticalStackLayout>

            <Border
                Stroke="#2A3342"
                StrokeThickness="1"
                BackgroundColor="#1F2937"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="Quiz topic"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#E5E7EB" />

                    <Border
                        BackgroundColor="#111827"
                        Stroke="#374151"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="12,4">

                        <Entry
                            x:Name="TopicEntry"
                            Placeholder="Enter topic, e.g. Present Simple"
                            PlaceholderColor="#6B7280"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            FontSize="16" />
                    </Border>

                    <HorizontalStackLayout Spacing="12">

                        <Button
                            x:Name="GenerateButton"
                            Text="Generate Quiz"
                            Clicked="OnGenerateQuizClicked"
                            Pressed="OnButtonPressed"
                            Released="OnButtonReleased"
                            HeightRequest="52"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            FontSize="15"
                            BackgroundColor="#A78BFA"
                            TextColor="#111827" />

                        <Button
                            x:Name="CheckButton"
                            Text="Check" 
                            Clicked="OnCheckQuizClicked"
                            Pressed="OnButtonPressed"
                            Released="OnButtonReleased"
                            HeightRequest="52"
                            CornerRadius="16"
                            FontAttributes="Bold"
                            FontSize="15"
                            BackgroundColor="#6366F1"
                            TextColor="White" />

                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="6">
                <Label
                    x:Name="StatusLabel"
                    FontSize="13"
                    TextColor="#9CA3AF" />

                <Label
                    x:Name="ScoreLabel"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#A78BFA" />
            </VerticalStackLayout>

            <CollectionView x:Name="QuizCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Padding="16"
                            Margin="0,6"
                            BackgroundColor="#1F2937"
                            Stroke="#2A3342"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20">

                            <VerticalStackLayout Spacing="10">

                                <Label
                                    Text="{Binding Question}"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    TextColor="White" />

                                <Label
                                    Text="Multiple Choice"
                                    FontAttributes="Italic"
                                    FontSize="12"
                                    TextColor="#9CA3AF"
                                    IsVisible="{Binding IsClosed}" />

                                <Label
                                    Text="Open Question"
                                    FontAttributes="Italic"
                                    FontSize="12"
                                    TextColor="#9CA3AF"
                                    IsVisible="{Binding IsOpen}" />

                                <Border
                                    BackgroundColor="#111827"
                                    Stroke="#374151"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="6"
                                    IsVisible="{Binding IsClosed}">

                                    <Picker
                                        Title="Select an answer"
                                        TitleColor="#6B7280"
                                        TextColor="White"
                                        BackgroundColor="Transparent"
                                        ItemsSource="{Binding Options}"
                                        SelectedItem="{Binding SelectedOption}" />
                                </Border>

                                <Border
                                    BackgroundColor="#111827"
                                    Stroke="#374151"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="10"
                                    IsVisible="{Binding IsOpen}">

                                    <Entry
                                        Placeholder="Type your answer"
                                        PlaceholderColor="#6B7280"
                                        TextColor="White"
                                        BackgroundColor="Transparent"
                                        Text="{Binding UserOpenAnswer}" />
                                </Border>

                                <Label
                                    Text="{Binding ResultText}"
                                    TextColor="{Binding ResultColor}"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    IsVisible="{Binding ShowResult}" />

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>