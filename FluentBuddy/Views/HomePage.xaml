<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home"
    BackgroundColor="#1E1E1E">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                Text="FluentBuddy"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#B794F4" />

            <Label
                Text="Your AI-powered English learning companion."
                FontSize="16"
                TextColor="White" />

            <Border
                Padding="16"
                BackgroundColor="#2A2A2A">
                
                <VerticalStackLayout Spacing="8">
                    <Label Text="Main Features" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="• AI Chat Practice" TextColor="White" />
                    <Label Text="• Grammar Correction" TextColor="White" />
                    <Label Text="• AI Dictionary" TextColor="White" />
                    <Label Text="• Quiz Generator" TextColor="White" />
                    <Label Text="• Cross-platform: Windows, Android, iOS" TextColor="#DDDDDD" />
                </VerticalStackLayout>
                
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>