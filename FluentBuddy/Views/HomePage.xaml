<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FluentBuddy.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                Text="FluentBuddy"
                FontSize="30"
                FontAttributes="Bold" />

            <Label
                Text="Your AI-powered English learning companion."
                FontSize="16" />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Main Features" FontSize="18" FontAttributes="Bold" />
                    <Label Text="• AI Chat Practice" />
                    <Label Text="• Grammar Correction" />
                    <Label Text="• Vocabulary Generator" />
                    <Label Text="• Cross-platform: Windows, Android, iOS" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>