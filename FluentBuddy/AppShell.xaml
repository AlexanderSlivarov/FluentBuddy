<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FluentBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FluentBuddy.Views"
    FlyoutBehavior="Flyout"
    Title="FluentBuddy">

    <TabBar>
        <ShellContent            
            Route="home"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent         
            Route="chat"
            Icon="chat.png"
            ContentTemplate="{DataTemplate views:ChatPage}" />

        <ShellContent           
            Route="grammar"
            Icon="grammar.png"
            ContentTemplate="{DataTemplate views:GrammarPage}" />

        <ShellContent           
            Route="dictionary"
            Icon="dictionary.png"
            ContentTemplate="{DataTemplate views:DictionaryPage}" />

        <ShellContent           
            Route="quiz"
            Icon="quiz.png"
            ContentTemplate="{DataTemplate views:QuizPage}" />
    </TabBar>

    <ShellContent
        Route="settings"
        ContentTemplate="{DataTemplate views:SettingsPage}"/>

</Shell>