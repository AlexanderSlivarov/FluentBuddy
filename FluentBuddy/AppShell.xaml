<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FluentBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FluentBuddy.Views"
    Title="FluentBuddy">

    <TabBar>
        <ShellContent
        Title="Home"
        Route="home"
        ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
        Title="Chat"
        Route="chat"
        ContentTemplate="{DataTemplate views:ChatPage}" />

        <ShellContent
        Title="Grammar"
        Route="grammar"
        ContentTemplate="{DataTemplate views:GrammarPage}" />

        <ShellContent
        Title="Dictionary"
        Route="dictionary"
        ContentTemplate="{DataTemplate views:DictionaryPage}" />

        <ShellContent
        Title="Quiz"
        Route="quiz"
        ContentTemplate="{DataTemplate views:QuizPage}" />

        <ShellContent
        Title="Settings"
        Route="settings"
        ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>