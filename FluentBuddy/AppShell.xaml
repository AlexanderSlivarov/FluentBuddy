<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FluentBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FluentBuddy.Views"
    FlyoutBehavior="Flyout"
    Title="FluentBuddy"    
    Shell.BackgroundColor="#101014"
    Shell.FlyoutBackgroundColor="#101014"
    Shell.ForegroundColor="White"
    Shell.TitleColor="#9B6DFF"
    Shell.UnselectedColor="#8E8EA0"
    Shell.DisabledColor="#5E5E6B"
    Shell.NavBarHasShadow="False">

    <FlyoutItem
        Title="Home"
        Route="home"
        Icon="home.png">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:HomePage}" />
    </FlyoutItem>

    <FlyoutItem
        Title="Chat"
        Route="chat"
        Icon="chat.png">
        <ShellContent
            Title="Chat"
            ContentTemplate="{DataTemplate views:ChatPage}" />
    </FlyoutItem>

    <FlyoutItem
        Title="Grammar"
        Route="grammar"
        Icon="grammar.png">
        <ShellContent
            Title="Grammar"
            ContentTemplate="{DataTemplate views:GrammarPage}" />
    </FlyoutItem>

    <FlyoutItem
        Title="Dictionary"
        Route="dictionary"
        Icon="dictionary.png">
        <ShellContent
            Title="Dictionary"
            ContentTemplate="{DataTemplate views:DictionaryPage}" />
    </FlyoutItem>

    <FlyoutItem
        Title="Quiz"
        Route="quiz"
        Icon="quiz.png">
        <ShellContent
            Title="Quiz"
            ContentTemplate="{DataTemplate views:QuizPage}" />
    </FlyoutItem>

    <FlyoutItem
        Title="Settings"
        Route="settings"
        Icon="settings.png">
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>

    <ShellContent
        Route="settings"
        FlyoutItemIsVisible="True"
        ContentTemplate="{DataTemplate views:SettingsPage}" />

</Shell>